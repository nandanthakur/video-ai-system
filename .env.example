# Video AI System Environment Variables
# Copy to .env and update values

# =============================================================================
# Security - Change these in production!
# =============================================================================
MILESTONE_PASSWORD=your_password
POSTGRES_PASSWORD=postgres
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
SESSION_SECRET=change-this-secret-in-production
JWT_SECRET=change-this-jwt-secret-in-production

# =============================================================================
# Database
# =============================================================================
POSTGRES_DB=video_ai
POSTGRES_USER=postgres
# POSTGRES_PASSWORD set above

# =============================================================================
# MinIO
# =============================================================================
MINIO_BUCKET=video-ai
# MINIO_ACCESS_KEY set above
# MINIO_SECRET_KEY set above

# =============================================================================
# Milestone VMS
# =============================================================================
MILESTONE_HOST=192.168.1.100
MILESTONE_PORT=443
MILESTONE_USERNAME=admin
# MILESTONE_PASSWORD set above

# =============================================================================
# Milestone AI Bridge
# =============================================================================
AI_BRIDGE_HOST=localhost
AI_BRIDGE_PORT=4000

# =============================================================================
# Kafka
# =============================================================================
KAFKA_TOPIC_PREFIX=video-ai
# KAFKA_BROKERS set in docker-compose

# =============================================================================
# Processing
# =============================================================================
DEFAULT_PRE_ALARM_SECONDS=5
DEFAULT_POST_ALARM_SECONDS=5
KAFKA_GROUP_ID=temporal-worker
KAFKA_TOPIC=video-ai-processing